<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import java.net.URL?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="root-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.GaleriaController" style="-fx-background-image: url('/com/mycompany/entreSombrasETeias/jogo/imagens/homemaranhainicial.jpg'); -fx-background-size: cover; -fx-background-position: center;">
   <stylesheets>
       <URL value="@../css/estilo.css" />
   </stylesheets>
   <children>
      <Label layoutX="210.0" layoutY="30.0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-family: 'Courier New'; -fx-font-weight: bold;" text="GALERIA DE IMAGENS / CONQUISTAS" />
      
      <ImageView fitHeight="400.0" fitWidth="700.0" layoutX="50.0" layoutY="90.0" pickOnBounds="true">
         <image>
            <Image url="/com/mycompany/entreSombrasETeias/jogo/imagens/imagemdolivro.png" />
         </image>
      </ImageView>

      <GridPane fx:id="gridGaleria" hgap="30.0" layoutX="110.0" layoutY="130.0" prefHeight="320.0" prefWidth="580.0" vgap="20.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
      </GridPane>
      
      <Button layoutX="80.0" layoutY="510.0" mnemonicParsing="false" onAction="#voltarMenu" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #ff2222; -fx-text-fill: black; -fx-font-family: 'Courier New'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="VOLTAR" />
   </children>
</AnchorPane>