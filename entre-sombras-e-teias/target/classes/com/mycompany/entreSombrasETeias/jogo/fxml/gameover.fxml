<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" 
            style="-fx-background-image: url('com/mycompany/entreSombrasETeias/jogo/imagens/gameover.jpg'); -fx-background-size: cover; -fx-background-position: center;" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.entreSombrasETeias.controller.GameOverController">
   <children>
      <AnchorPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
      
      <Label text="GAME OVER" 
             AnchorPane.topAnchor="120.0" 
             AnchorPane.leftAnchor="60.0" 
             style="-fx-text-fill: #ff2211; -fx-font-size: 48px; -fx-font-family: 'Press Start 2P'; -fx-effect: dropshadow(three-pass-box, black, 5, 0.0, 3, 3);" />
      
      <HBox alignment="CENTER" 
            AnchorPane.bottomAnchor="80.0" 
            AnchorPane.leftAnchor="0.0" 
            AnchorPane.rightAnchor="0.0">
         <children>
            <Button onAction="#voltarMenu" 
                    text="VOLTAR PARA O MENU INICIAL" 
                    style="-fx-background-color: #800000; -fx-text-fill: black; -fx-font-size: 14px; -fx-font-family: 'Press Start 2P'; -fx-padding: 15 30 15 30; -fx-border-color: black; -fx-border-width: 2; -fx-cursor: hand; -fx-min-width: -Infinity; -fx-max-width: -Infinity;" />
         </children>
      </HBox>
   </children>
</AnchorPane>