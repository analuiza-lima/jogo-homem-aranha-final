<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.CreditosController" styleClass="vbox-container">
   <stylesheets>
       <URL value="@../css/estilo.css" />
   </stylesheets>
   <children>
      <Label text="🎬 CRÉDITOS DO JOGO" styleClass="titulo-tela" style="-fx-text-fill: #e63946;" />
      <Label text="Entre Sombras e Teias" styleClass="subtitulo-tela" style="-fx-font-style: italic; -fx-font-size: 16;" />

      <VBox alignment="CENTER" spacing="8.0" styleClass="painel-interno">
         <children>
            <Label text="DESENVOLVIDO POR:" styleClass="label-xp" style="-fx-font-size: 14;" />
            <Label text="Ana Luiza Teixeira Lima" styleClass="label-jogador" style="-fx-font-size: 16;" />
            <Label text="Bruna Pereira Teodosio Martins" styleClass="label-jogador" style="-fx-font-size: 16;" />
         </children>
         <VBox.margin>
            <Insets top="10.0" bottom="10.0" />
         </VBox.margin>
      </VBox>

      <Label text="Tecnologias: Java, JavaFX, PostgreSQL e JDBC (Padrão MVC)" styleClass="subtitulo-tela" style="-fx-font-size: 12; -fx-text-fill: #6c757d;" />
      <Label text="Trabalho Prático - Instituto Federal de Mato Grosso do Sul" styleClass="subtitulo-tela" style="-fx-font-size: 12; -fx-text-fill: #6c757d;" />

      <Button text="🚪 VOLTAR AO MENU" onAction="#voltar" styleClass="btn-padrao, btn-escuro" style="-fx-min-width: 180;" />
   </children>
</VBox>