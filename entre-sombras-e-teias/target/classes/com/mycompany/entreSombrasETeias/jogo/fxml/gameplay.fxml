<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.GameplayController">
   <children>
      <AnchorPane maxHeight="600.0" maxWidth="800.0" minHeight="600.0" minWidth="800.0" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: black; -fx-font-family: 'Press Start 2P';">
         <children>
            <ImageView fitHeight="350.0" fitWidth="800.0" opacity="0.4" pickOnBounds="true">
               <image>
                  <Image url="/com/mycompany/entreSombrasETeias/jogo/imagens/gotham-city.png" />
               </image>
            </ImageView>
            <AnchorPane layoutY="15.0" prefHeight="200.0" prefWidth="800.0">
               <children>
                  <VBox alignment="CENTER" layoutX="160.0" layoutY="0.0" prefWidth="480.0" spacing="6.0">
                     <children>
                        <Label fx:id="labelVilaoNome" style="-fx-text-fill: #ffd700; -fx-font-size: 11px;" text="VILÃO" />
                        <ProgressBar fx:id="barraHpVilao" prefWidth="200.0" progress="1.0" style="-fx-accent: #ffd700;" />
                        <Label fx:id="labelHpVilao" style="-fx-text-fill: white; -fx-font-size: 9px;" text="HP: --/--" />
                        <ImageView fx:id="imgVilao" fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </VBox>
                  <AnchorPane fx:id="painelBalaoVilao" layoutX="540.0" layoutY="60.0" prefHeight="85.0" prefWidth="230.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-width: 3;">
                     <children>
                        <Label fx:id="labelDialogoVilao" alignment="TOP_LEFT" layoutX="12.0" layoutY="12.0" prefHeight="60.0" prefWidth="206.0" style="-fx-text-fill: black; -fx-font-size: 10px; -fx-wrap-text: true;" text="Fala do Vilão..." />
                     </children>
                  </AnchorPane>
               </children>
            </AnchorPane>
            <AnchorPane fx:id="caixaCombateUndertale" focusTraversable="true" layoutX="160.0" layoutY="230.0" prefHeight="140.0" prefWidth="480.0" style="-fx-background-color: black; -fx-border-color: white; -fx-border-width: 4;">
               <children>
                  <ImageView fx:id="iconeCoracaoAranha" fitHeight="120.0" fitWidth="120.0" layoutX="180.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />
                  <Label fx:id="labelStatusTurno" alignment="TOP_LEFT" layoutX="20.0" layoutY="20.0" prefHeight="100.0" prefWidth="440.0" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-wrap-text: true;" text="* Narrador: Uma presença sombria surge..." />
               </children>
            </AnchorPane>
            <HBox alignment="CENTER" layoutX="160.0" layoutY="390.0" prefWidth="480.0" spacing="15.0">
               <children>
                  <Label fx:id="labelHpJogador" style="-fx-text-fill: white; -fx-font-size: 11px;" text="PETER HP: 100/100" />
                  <ProgressBar fx:id="barraHpJogador" prefWidth="240.0" progress="1.0" style="-fx-accent: #ff2211;" />
               </children>
            </HBox>
            <AnchorPane layoutY="450.0" prefHeight="150.0" prefWidth="800.0" style="-fx-background-color: #050505; -fx-border-color: white; -fx-border-width: 3 0 0 0;">
               <children>
                  <ImageView fx:id="imgPeterIcone" fitHeight="100.0" fitWidth="100.0" layoutX="30.0" layoutY="25.0" pickOnBounds="true" preserveRatio="true" />
                  <AnchorPane fx:id="painelBalaoPeter" layoutX="140.0" layoutY="20.0" prefHeight="110.0" prefWidth="620.0">
                     <children>
                        <Label fx:id="labelDialogoPeter" alignment="TOP_LEFT" layoutX="10.0" layoutY="10.0" prefHeight="60.0" prefWidth="600.0" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-wrap-text: true;" text="Peter: ..." />
                        <Button fx:id="btnAvancarDialogo" layoutX="460.0" layoutY="70.0" onAction="#avancarDialogo" prefHeight="30.0" prefWidth="140.0" style="-fx-background-color: #ff2211; -fx-text-fill: white; -fx-font-size: 10px; -fx-cursor: hand;" text="AVANÇAR ➡️" />
                     </children>
                  </AnchorPane>
                  <HBox fx:id="painelBotoesLuta" alignment="CENTER" layoutX="140.0" layoutY="45.0" spacing="25.0" visible="false">
                     <children>
                        <Button fx:id="btnAtacarAranha" onAction="#atacarAranha" prefHeight="60.0" prefWidth="180.0" style="-fx-background-color: black; -fx-text-fill: #ff2211; -fx-border-color: #ff2211; -fx-border-width: 3; -fx-font-size: 12px; -fx-cursor: hand;" text="⚔ ATACAR" />
                        <Button fx:id="btnRecuperar" onAction="#recuperar" prefHeight="60.0" prefWidth="180.0" style="-fx-background-color: black; -fx-text-fill: #0077ff; -fx-border-color: #0077ff; -fx-border-width: 3; -fx-font-size: 12px; -fx-cursor: hand;" text="🎒 ITENS" />
                        <Button fx:id="btnFugir" onAction="#fugir" prefHeight="60.0" prefWidth="180.0" style="-fx-background-color: black; -fx-text-fill: #888888; -fx-border-color: #888888; -fx-border-width: 3; -fx-font-size: 12px; -fx-cursor: hand;" text="🏃 FUGIR" />
                     </children>
                  </HBox>
               </children>
            </AnchorPane>
         </children>
      </AnchorPane>
   </children>
</StackPane>