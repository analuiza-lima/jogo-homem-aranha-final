<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="800.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.GameplayController">
   <children>
      
      <VBox alignment="CENTER" layoutX="200.0" layoutY="20.0" spacing="8.0">
         <Label fx:id="labelVilaoNome" text="VILÃO" textFill="WHITE">
            <font>
               <Font name="Courier New Bold" size="22.0" />
            </font>
         </Label>
         <StackPane fx:id="containerVilao" prefHeight="120.0" prefWidth="400.0">
            <ImageView fx:id="imgVilao" fitHeight="120.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
            <Label fx:id="labelDanoPopup" text="-0 HP" textFill="RED" visible="false">
               <font>
                  <Font name="Courier New Bold" size="26.0" />
               </font>
            </Label>
         </StackPane>
         <ProgressBar fx:id="barraHpVilao" prefWidth="400.0" progress="1.0" style="-fx-accent: #ff0000;" />
      </VBox>

      <AnchorPane fx:id="caixaCombateUndertale" layoutX="80.0" layoutY="200.0" prefHeight="150.0" prefWidth="640.0" style="-fx-border-color: #ffffff; -fx-border-width: 4; -fx-background-color: #050505;">
         <children>
            <ImageView fx:id="iconeCoracaoAranha" fitHeight="32.0" fitWidth="32.0" layoutX="304.0" layoutY="59.0" pickOnBounds="true" preserveRatio="true" visible="false" />
         </children>
      </AnchorPane>

      <AnchorPane fx:id="painelBalaoPeter" layoutX="80.0" layoutY="370.0" prefHeight="110.0" prefWidth="640.0" style="-fx-background-color: #111111; -fx-border-color: #ffffff; -fx-border-width: 2;">
         <children>
            <Label fx:id="labelDialogoPeter" alignment="TOP_LEFT" layoutX="20.0" layoutY="15.0" prefHeight="80.0" prefWidth="460.0" text="Narrativa ou fala do Peter..." textFill="WHITE" wrapText="true">
               <font>
                  <Font name="Courier New" size="15.0" />
               </font>
            </Label>
            <Button fx:id="btnAvancarDialogo" layoutX="500.0" layoutY="35.0" mnemonicParsing="false" onAction="#avancarDialogo" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #222222; -fx-border-color: #ffffff; -fx-text-fill: #ffffff;" text="CONTINUAR">
               <font>
                  <Font name="Courier New Bold" size="13.0" />
               </font>
            </Button>
         </children>
      </AnchorPane>

      <AnchorPane fx:id="painelBalaoVilao" layoutX="120.0" layoutY="130.0" prefHeight="65.0" prefWidth="300.0" style="-fx-background-color: #1a0000; -fx-border-color: #ff0000; -fx-border-width: 2;" visible="false">
         <children>
            <Label fx:id="labelDialogoVilao" alignment="TOP_LEFT" layoutX="10.0" layoutY="8.0" prefHeight="50.0" prefWidth="280.0" text="Fala do Vilão..." textFill="#ffcccc" wrapText="true">
               <font>
                  <Font name="Courier New Bold" size="13.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>

      <AnchorPane fx:id="painelMinigameAtaque" layoutX="80.0" layoutY="370.0" prefHeight="110.0" prefWidth="640.0" style="-fx-background-color: #151515; -fx-border-color: #00ff00; -fx-border-width: 2;" visible="false">
         <children>
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#00ff00" height="90.0" layoutX="302.0" layoutY="10.0" stroke="BLACK" strokeType="INSIDE" width="20.0" />
            <Label layoutX="240.0" layoutY="10.0" text="CRÍTICO" textFill="#00ff00">
               <font>
                  <Font name="Courier New Bold" size="12.0" />
               </font>
            </Label>
            <Region fx:id="barraMarcadorRitmo" layoutX="20.0" layoutY="10.0" prefHeight="90.0" prefWidth="10.0" style="-fx-background-color: #ffffff;" />
            <Label layoutX="14.0" layoutY="85.0" text="Pressione [ESPAÇO] ou [ENTER] no tempo certo!" textFill="WHITE">
               <font>
                  <Font name="Courier New" size="11.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>

      <HBox alignment="CENTER" layoutX="80.0" layoutY="500.0" prefWidth="640.0" spacing="40.0">
         <Label fx:id="labelLvlJogador" text="LVL: 1" textFill="WHITE">
            <font>
               <Font name="Courier New Bold" size="16.0" />
            </font>
         </Label>
         <VBox spacing="4.0">
            <Label fx:id="labelHpJogador" text="HP: 100/100" textFill="WHITE">
               <font>
                  <Font name="Courier New Bold" size="14.0" />
               </font>
            </Label>
            <ProgressBar fx:id="barraHpJogador" prefWidth="200.0" progress="1.0" style="-fx-accent: #00ff00;" />
         </VBox>
         <Label fx:id="labelSuperStatus" text="SUPER: 0/120" textFill="#00ffff">
            <font>
               <Font name="Courier New Bold" size="16.0" />
            </font>
         </Label>
      </HBox>

      <Label fx:id="labelStatusTurno" alignment="CENTER" layoutX="80.0" layoutY="545.0" prefWidth="640.0" text="O que o Aranha vai fazer?" textFill="YELLOW" visible="false">
         <font>
            <Font name="Courier New Bold" size="16.0" />
         </font>
      </Label>

      <StackPane layoutX="80.0" layoutY="580.0" prefHeight="50.0" prefWidth="640.0">
         
         <HBox fx:id="painelBotoesLuta" alignment="CENTER" spacing="30.0" visible="false">
            <Button fx:id="btnAtacarAranha" mnemonicParsing="false" onAction="#mostrarOpcoesAtaque" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #000000; -fx-border-color: #ff3333; -fx-border-width: 2; -fx-text-fill: #ff3333;" text="⚔ ATACAR">
               <font>
                  <Font name="Courier New Bold" size="16.0" />
               </font>
            </Button>
            <Button fx:id="btnRecuperar" mnemonicParsing="false" onAction="#mostrarOpcoesRecuperar" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #000000; -fx-border-color: #33cc33; -fx-border-width: 2; -fx-text-fill: #33cc33;" text="❤ CURAR">
               <font>
                  <Font name="Courier New Bold" size="16.0" />
               </font>
            </Button>
            <Button fx:id="btnFugir" mnemonicParsing="false" onAction="#executarFugir" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #000000; -fx-border-color: #ffffff; -fx-border-width: 2; -fx-text-fill: #ffffff;" text="🏃 FUGIR">
               <font>
                  <Font name="Courier New Bold" size="16.0" />
               </font>
            </Button>
         </HBox>

         <HBox fx:id="painelSubAtaques" alignment="CENTER" spacing="20.0" visible="false">
            <Button mnemonicParsing="false" onAction="#iniciarMinigameOnda" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #111111; -fx-border-color: #ffaa00; -fx-text-fill: #ffaa00;" text="💥 ONDA DE TEIA">
               <font>
                  <Font name="Courier New Bold" size="14.0" />
               </font>
            </Button>
            <Button fx:id="btnAtaqueSuper" mnemonicParsing="false" onAction="#iniciarMinigameSuper" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #111111; -fx-border-color: #00ffff; -fx-text-fill: #00ffff;" text="⚡ ATAQUE SUPER">
               <font>
                  <Font name="Courier New Bold" size="14.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#voltarParaMenuLuta" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #222222; -fx-text-fill: #ffffff;" text="VOLTAR">
               <font>
                  <Font name="Courier New" size="14.0" />
               </font>
            </Button>
         </HBox>

         <HBox fx:id="painelSubRecuperar" alignment="CENTER" spacing="20.0" visible="false">
            <Button mnemonicParsing="false" onAction="#usarSentidoAranha" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #111111; -fx-border-color: #33cc33; -fx-text-fill: #33cc33;" text="👁 SENTIDO ARANHA (+15)">
               <font>
                  <Font name="Courier New Bold" size="13.0" />
               </font>
            </Button>
            <Button fx:id="btnSuplemento" mnemonicParsing="false" onAction="#usarSuplemento" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #111111; -fx-border-color: #ff00ff; -fx-text-fill: #ff00ff;" text="🥤 SUPLEMENTO (3)">
               <font>
                  <Font name="Courier New Bold" size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#voltarParaMenuLuta" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #222222; -fx-text-fill: #ffffff;" text="VOLTAR">
               <font>
                  <Font name="Courier New" size="14.0" />
               </font>
            </Button>
         </HBox>
      </StackPane>

      <ImageView fx:id="imgPeterIcone" fitHeight="90.0" fitWidth="90.0" layoutX="680.0" layoutY="490.0" pickOnBounds="true" preserveRatio="true" />

   </children>
</AnchorPane>