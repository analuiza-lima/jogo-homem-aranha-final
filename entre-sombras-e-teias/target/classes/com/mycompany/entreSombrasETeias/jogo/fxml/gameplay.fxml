<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.GameplayController">
   <children>
      <AnchorPane prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: black; -fx-font-family: 'Press Start 2P';">
         <children>
            
            <ImageView fitHeight="420.0" pickOnBounds="true" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <image>
                  <Image url="/com/mycompany/entreSombrasETeias/jogo/imagens/gotham-city.png" />
               </image>
            </ImageView>
            
            <VBox alignment="CENTER" spacing="10.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="15.0">
               <children>
                  <Label fx:id="labelVilaoNome" style="-fx-text-fill: #ff2211; -fx-font-size: 16px; -fx-font-weight: bold;" text="DUENDE VERDE" />
                  
                  <ProgressBar fx:id="barraHpVilao" prefHeight="22.0" prefWidth="300.0" progress="0.7" style="-fx-accent: #ff2211; -fx-border-color: black; -fx-border-width: 3;" />
                  
                  <StackPane fx:id="containerVilao" prefHeight="260.0" prefWidth="300.0">
                     <children>
                        <ImageView fx:id="imgVilao" fitHeight="260.0" fitWidth="260.0" pickOnBounds="true" preserveRatio="true" />
                        
                        <Label fx:id="labelDanoPopup" style="-fx-text-fill: #ff2211; -fx-font-size: 32px; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, black, 4, 0, 0, 0);" text="40" visible="false" StackPane.alignment="CENTER" />
                     </children>
                  </StackPane>
               </children>
            </VBox>

            <AnchorPane fx:id="painelBalaoVilao" layoutX="580.0" layoutY="80.0" prefHeight="90.0" prefWidth="230.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-width: 4;" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="80.0">
               <children>
                  <Label fx:id="labelDialogoVilao" alignment="TOP_LEFT" layoutX="15.0" layoutY="15.0" prefHeight="60.0" prefWidth="200.0" style="-fx-text-fill: black; -fx-font-size: 11px; -fx-wrap-text: true;" text="HAHAHA! O que você vai fazer?" />
               </children>
            </AnchorPane>
            
            <AnchorPane fx:id="caixaCombateUndertale" focusTraversable="true" layoutX="100.0" layoutY="310.0" prefHeight="140.0" prefWidth="650.0" style="-fx-background-color: black; -fx-border-color: white; -fx-border-width: 5;" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0">
               <children>
                  <Label fx:id="labelStatusTurno" alignment="TOP_LEFT" layoutX="25.0" layoutY="20.0" prefHeight="100.0" prefWidth="600.0" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-wrap-text: true;" text="* Duende Verde te atacou! O que você vai fazer?" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" />
                  <ImageView fx:id="iconeCoracaoAranha" fitHeight="24.0" fitWidth="24.0" layoutX="30.0" layoutY="58.0" pickOnBounds="true" preserveRatio="true" visible="false" />
                  
                  <AnchorPane fx:id="painelMinigameAtaque" prefHeight="130.0" prefWidth="640.0" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <children>
                        <Region layoutX="316.0" layoutY="10.0" prefHeight="110.0" prefWidth="8.0" style="-fx-background-color: #00ff00; -fx-border-color: white; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.topAnchor="10.0" />
                        <Region layoutX="250.0" layoutY="10.0" prefHeight="110.0" prefWidth="4.0" style="-fx-background-color: #ffd700;" AnchorPane.bottomAnchor="10.0" AnchorPane.topAnchor="10.0" />
                        <Region layoutX="386.0" layoutY="10.0" prefHeight="110.0" prefWidth="4.0" style="-fx-background-color: #ffd700;" AnchorPane.bottomAnchor="10.0" AnchorPane.topAnchor="10.0" />
                        
                        <Region fx:id="barraMarcadorRitmo" layoutX="20.0" layoutY="8.0" prefHeight="114.0" prefWidth="12.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(255,255,255,0.8), 5, 0, 0, 0);" />
                     </children>
                  </AnchorPane>
               </children>
            </AnchorPane>
            
            <HBox alignment="CENTER_LEFT" layoutX="100.0" layoutY="460.0" prefWidth="650.0" spacing="15.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0">
               <children>
                  <Label fx:id="labelHpJogador" style="-fx-text-fill: white; -fx-font-size: 14px;" text="HP: 50/100" />
                  <ProgressBar fx:id="barraHpJogador" prefHeight="18.0" prefWidth="200.0" progress="0.5" style="-fx-accent: #ff2211; -fx-border-color: white; -fx-border-width: 1;" />
                  <Label fx:id="labelLvlJogador" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 30px;" text="LVL: 6" />
                  <Label fx:id="labelSuperStatus" style="-fx-text-fill: #ffd700; -fx-font-size: 11px; -fx-padding: 0 0 0 20px;" text="SUPER: 0/120" />
               </children>
            </HBox>
            
            <AnchorPane prefHeight="145.0" prefWidth="800.0" style="-fx-background-color: #cccccc; -fx-border-color: black; -fx-border-width: 5 0 0 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
               <children>
                  
                  <HBox alignment="CENTER" layoutX="25.0" layoutY="18.0" prefHeight="105.0" prefWidth="105.0" style="-fx-background-color: black; -fx-border-color: black; -fx-border-width: 2;">
                     <children>
                        <ImageView fx:id="imgPeterIcone" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </HBox>
                  
                  <AnchorPane fx:id="painelBalaoPeter" layoutX="150.0" layoutY="10.0" prefHeight="125.0" prefWidth="680.0" AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="15.0">
                     <children>
                        <Label fx:id="labelDialogoPeter" alignment="TOP_LEFT" layoutX="10.0" layoutY="15.0" prefHeight="60.0" prefWidth="640.0" style="-fx-text-fill: black; -fx-font-size: 13px; -fx-font-weight: bold; -fx-wrap-text: true;" text="Duende verde..." AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" />
                        <Button fx:id="btnAvancarDialogo" layoutX="500.0" layoutY="75.0" onAction="#avancarDialogo" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-font-family: 'Press Start 2P'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-color: black; -fx-border-width: 3; -fx-cursor: hand;" text="PRÓXIMO &gt;" AnchorPane.rightAnchor="10.0" />
                     </children>
                  </AnchorPane>
                  
                  <HBox fx:id="painelBotoesLuta" alignment="CENTER" layoutX="150.0" layoutY="40.0" spacing="20.0" visible="false" AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="15.0">
                     <children>
                        <Button fx:id="btnAtacarAranha" onAction="#mostrarOpcoesAtaque" prefHeight="65.0" prefWidth="200.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="ATACAR |" />
                        <Button fx:id="btnRecuperar" onAction="#mostrarOpcoesRecuperar" prefHeight="65.0" prefWidth="200.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="RECUPERAR" />
                        <Button fx:id="btnFugir" onAction="#executarFugir" prefHeight="65.0" prefWidth="200.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="FUGIR |" />
                     </children>
                  </HBox>

                  <HBox fx:id="painelSubAtaques" alignment="CENTER" layoutX="150.0" layoutY="40.0" spacing="20.0" visible="false" AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="15.0">
                     <children>
                        <Button fx:id="btnAtaqueOnda" onAction="#iniciarMinigameOnda" prefHeight="65.0" prefWidth="240.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;" text="🕷️ ONDA ARANHAS" />
                        <Button fx:id="btnAtaqueSuper" onAction="#iniciarMinigameSuper" prefHeight="65.0" prefWidth="240.0" style="-fx-background-color: #cccccc; -fx-text-fill: #888888; -fx-border-color: #888888; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;" text="🕸️ SUPER TEIA" />
                        <Button onAction="#voltarParaMenuLuta" prefHeight="65.0" prefWidth="130.0" style="-fx-background-color: #ff2211; -fx-text-fill: white; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;" text="VOLTAR" />
                     </children>
                  </HBox>

                  <HBox fx:id="painelSubRecuperar" alignment="CENTER" layoutX="150.0" layoutY="40.0" spacing="20.0" visible="false" AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="15.0">
                     <children>
                        <Button fx:id="btnSentidoAranha" onAction="#usarSentidoAranha" prefHeight="65.0" prefWidth="240.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;" text="⚡ SENTIDO ARANHA" />
                        <Button fx:id="btnSuplemento" onAction="#usarSuplemento" prefHeight="65.0" prefWidth="240.0" style="-fx-background-color: #cccccc; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;" text="🥤 SUPLEMENTO" />
                        <Button onAction="#voltarParaMenuLuta" prefHeight="65.0" prefWidth="130.0" style="-fx-background-color: #ff2211; -fx-text-fill: white; -fx-border-color: black; -fx-border-width: 4; -fx-background-radius: 0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;" text="VOLTAR" />
                     </children>
                  </HBox>
                  
               </children>
            </AnchorPane>
            
            <VBox fx:id="telaGameOver" alignment="CENTER" spacing="30.0" style="-fx-background-color: rgba(0,0,0,0.95);" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <Label style="-fx-text-fill: #ff2211; -fx-font-size: 40px; -fx-font-weight: bold;" text="GAME OVER" />
                  <Button onAction="#voltarMenuInicial" prefHeight="50.0" prefWidth="280.0" style="-fx-background-color: black; -fx-text-fill: white; -fx-border-color: white; -fx-border-width: 3; -fx-background-radius: 0; -fx-font-size: 14px; -fx-cursor: hand;" text="VOLTAR AO MENU" />
               </children>
            </VBox>

         </children>
      </AnchorPane>
   </children>
</StackPane>