<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Button?>
<?import java.net.URL?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.entreSombrasETeias.controller.JogarController"
            prefWidth="800" prefHeight="600"
            style="-fx-background-image: url('com/mycompany/entreSombrasETeias/jogo/imagens/homemaranhainicial.jpg'); -fx-background-size: cover; -fx-background-position: center; -fx-font-family: 'Press Start 2P';">
    
    <stylesheets>
        <URL value="@../css/estilo.css" />
    </stylesheets>

    <Button fx:id="btnModoHistoria" 
            text="modo historia" 
            onAction="#handleModoHistoria" 
            prefHeight="76.0" prefWidth="168.0" 
            textAlignment="CENTER" wrapText="true"
            style="-fx-background-color: #ff2211; -fx-text-fill: black; -fx-font-family: 'Press Start 2P'; -fx-font-size: 11px; -fx-background-radius: 10; -fx-border-color: black; -fx-border-width: 2; -fx-border-radius: 10; -fx-cursor: hand;" 
            AnchorPane.topAnchor="64.0" 
            AnchorPane.leftAnchor="60.0" />

    <Button fx:id="btnTeiaConfrontos" 
            text="Teia de Confrontos" 
            onAction="#handleTeiaConfrontos" 
            prefHeight="76.0" prefWidth="168.0" 
            textAlignment="CENTER" wrapText="true"
            style="-fx-background-color: #ff2211; -fx-text-fill: black; -fx-font-family: 'Press Start 2P'; -fx-font-size: 11px; -fx-background-radius: 10; -fx-border-color: black; -fx-border-width: 2; -fx-border-radius: 10; -fx-cursor: hand;" 
            AnchorPane.bottomAnchor="64.0" 
            AnchorPane.rightAnchor="51.0" />

</AnchorPane>