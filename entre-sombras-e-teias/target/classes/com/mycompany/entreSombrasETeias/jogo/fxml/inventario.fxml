<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<AnchorPane prefWidth="650" prefHeight="650"
            styleClass="inventario-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.entreSombrasETeias.controller.InventarioController">

    <stylesheets>
        <URL value="@../css/estilo.css"/>
    </stylesheets>

    <children>

        <Label
                layoutX="185"
                layoutY="30"
                text="INVENTÁRIO"
                styleClass="titulo-inventario"/>

        <Label
                fx:id="labelHP"
                layoutX="60"
                layoutY="110"
                styleClass="info"/>

        <Label
                fx:id="labelXP"
                layoutX="420"
                layoutY="110"
                styleClass="info"/>

        <Separator layoutX="50" layoutY="160" prefWidth="550"/>

        <Label
                layoutX="60"
                layoutY="175"
                text="SUPLEMENTOS"
                styleClass="subtitulo"/>

        <ListView
                fx:id="listaItens"
                layoutX="60"
                layoutY="220"
                prefWidth="530"
                prefHeight="250"
                focusTraversable="false"/>

        <Label
                layoutX="120"
                layoutY="500"
                text="Cada suplemento restaura +15 HP."
                styleClass="descricao"/>

        <Button
                layoutX="250"
                layoutY="555"
                prefWidth="150"
                prefHeight="45"
                text="FECHAR"
                onAction="#fechar"
                styleClass="botao-pixel"/>

    </children>

</AnchorPane>