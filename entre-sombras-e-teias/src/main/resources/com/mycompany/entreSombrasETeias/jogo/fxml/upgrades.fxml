<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.UpgradesController" alignment="CENTER" spacing="20" styleClass="vbox-container">
    <stylesheets>
        <URL value="@../css/estilo.css" />
    </stylesheets>

    <Label text="⬆️ Upgrades" styleClass="titulo-tela"/>

    <HBox alignment="CENTER" spacing="40">
        <Label fx:id="labelXP" styleClass="label-jogador" style="-fx-font-size: 14;"/>
        <Label fx:id="labelHP" styleClass="label-hp" style="-fx-font-size: 14;"/>
    </HBox>

    <Label fx:id="labelMensagem" styleClass="subtitulo-tela" style="-fx-font-style: italic; -fx-font-size: 13;"/>

    <Button text="❤️  +20 HP Máximo" onAction="#upgradeHP" styleClass="btn-padrao, btn-vermelho" style="-fx-min-width: 300;"/>
    <Button text="⚔️  +Dano" onAction="#upgradeDano" styleClass="btn-padrao, btn-azul" style="-fx-min-width: 300;"/>
    <Button text="⚡  +Velocidade" onAction="#upgradeVelocidade" styleClass="btn-padrao, btn-verde" style="-fx-min-width: 300;"/>
    <Button text="▶  Continuar" onAction="#continuar" styleClass="btn-padrao, btn-escuro" style="-fx-min-width: 300;"/>
</VBox>