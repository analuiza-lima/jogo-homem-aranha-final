<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="tela-historia-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.entreSombrasETeias.controller.ModoHistoriaController">

    <stylesheets>
        <URL value="@../css/estilo.css" />
    </stylesheets>

    <HBox alignment="CENTER" spacing="50.0" styleClass="hud-status-barra" 
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <children>
            <Label fx:id="labelNome" styleClass="hud-texto-nome" text="Jogador" />
            <Label fx:id="labelHP" styleClass="hud-texto-hp" text="HP: 100/100" />
            <Label fx:id="labelXP" styleClass="hud-texto-xp" text="XP: 0" />
        </children>
    </HBox>

    <HBox alignment="CENTER" spacing="12.0" 
          AnchorPane.topAnchor="110.0" AnchorPane.bottomAnchor="120.0" 
          AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
        <children>
            
            <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card-episodio" HBox.hgrow="ALWAYS">
                <Label text="EP 01" styleClass="titulo-card-ep" />
                <AnchorPane styleClass="container-decorativo-aranha" VBox.vgrow="ALWAYS" />
                <Button fx:id="btnEp1" onAction="#jogarEp1" text="JOGAR" styleClass="botao-historia-acao" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card-episodio-bloqueado" HBox.hgrow="ALWAYS">
                <Label text="EP 02" styleClass="titulo-card-ep-bloqueado" />
                <AnchorPane styleClass="container-decorativo-teia" VBox.vgrow="ALWAYS" />
                <Button fx:id="btnEp2" onAction="#jogarEp2" text="🔒" styleClass="botao-historia-bloqueado" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card-episodio-bloqueado" HBox.hgrow="ALWAYS">
                <Label text="EP 03" styleClass="titulo-card-ep-bloqueado" />
                <AnchorPane styleClass="container-decorativo-teia" VBox.vgrow="ALWAYS" />
                <Button fx:id="btnEp3" onAction="#jogarEp3" text="🔒" styleClass="botao-historia-bloqueado" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card-episodio-bloqueado" HBox.hgrow="ALWAYS">
                <Label text="EP 04" styleClass="titulo-card-ep-bloqueado" />
                <AnchorPane styleClass="container-decorativo-teia" VBox.vgrow="ALWAYS" />
                <Button fx:id="btnEp4" onAction="#jogarEp4" text="🔒" styleClass="botao-historia-bloqueado" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card-episodio-bloqueado" HBox.hgrow="ALWAYS">
                <Label text="EP 05" styleClass="titulo-card-ep-bloqueado" />
                <AnchorPane styleClass="container-decorativo-teia" VBox.vgrow="ALWAYS" />
                <Button fx:id="btnEp5" onAction="#jogarEp5" text="🔒" styleClass="botao-historia-bloqueado" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card-episodio-bloqueado" HBox.hgrow="ALWAYS">
                <Label text="EP 06" styleClass="titulo-card-ep-bloqueado" />
                <AnchorPane styleClass="container-decorativo-teia" VBox.vgrow="ALWAYS" />
                <Button fx:id="btnEp6" onAction="#jogarEp6" text="🔒" styleClass="botao-historia-bloqueado" />
            </VBox>

        </children>
    </HBox>

    <HBox alignment="CENTER" spacing="30.0" prefHeight="60.0"
          AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
        <children>
            <Button onAction="#abrirInventario" text="🎒 INVENTÁRIO" styleClass="botao-historia-navegacao-azul" />
            <Button onAction="#voltarMenu" text="← VOLTAR" styleClass="botao-voltar-pixel" />
        </children>
    </HBox>

</AnchorPane>