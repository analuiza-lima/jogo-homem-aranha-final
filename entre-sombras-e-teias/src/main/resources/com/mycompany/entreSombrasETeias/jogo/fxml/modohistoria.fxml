<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import java.net.URL?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" 
            style="-fx-background-image: url('com/mycompany/entreSombrasETeias/jogo/imagens/homemaranhainicial.jpg'); -fx-background-size: cover; -fx-background-position: center; -fx-font-family: 'Press Start 2P';" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.entreSombrasETeias.controller.ModoHistoriaController">

    <stylesheets>
        <URL value="@../css/estilo.css" />
    </stylesheets>

    <HBox alignment="CENTER" spacing="30.0" style="-fx-background-color: rgba(0,0,0,0.6); -fx-padding: 10;" 
          AnchorPane.topAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
        <children>
            <Label fx:id="labelNome" style="-fx-text-fill: white; -fx-font-size: 12px;" text="Jogador" />
            <Label fx:id="labelHP" style="-fx-text-fill: #ff2222; -fx-font-size: 12px;" text="HP: 100/100" />
            <Label fx:id="labelXP" style="-fx-text-fill: #ffd700; -fx-font-size: 12px;" text="XP: 0" />
        </children>
    </HBox>

    <HBox alignment="CENTER" spacing="15.0" AnchorPane.topAnchor="140.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
        <children>
            
            <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.75); -fx-padding: 15; -fx-border-color: #333; -fx-border-width: 2; -fx-pref-width: 130;">
                <Label text="EP 01" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                <Button fx:id="btnEp1" text="JOGAR" onAction="#jogarEp1" style="-fx-background-color: #ff2211; -fx-text-fill: black; -fx-font-size: 10px; -fx-cursor: hand; -fx-pref-width: 110; -fx-pref-height: 40; -fx-font-family: 'Press Start 2P';" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.75); -fx-padding: 15; -fx-border-color: #333; -fx-border-width: 2; -fx-pref-width: 130;">
                <Label text="EP 02" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                <Button fx:id="btnEp2" text="🔒" onAction="#jogarEp2" style="-fx-background-color: #444; -fx-text-fill: #888; -fx-font-size: 10px; -fx-pref-width: 110; -fx-pref-height: 40; -fx-font-family: 'Press Start 2P';" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.75); -fx-padding: 15; -fx-border-color: #333; -fx-border-width: 2; -fx-pref-width: 130;">
                <Label text="EP 03" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                <Button fx:id="btnEp3" text="🔒" onAction="#jogarEp3" style="-fx-background-color: #444; -fx-text-fill: #888; -fx-font-size: 10px; -fx-pref-width: 110; -fx-pref-height: 40; -fx-font-family: 'Press Start 2P';" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.75); -fx-padding: 15; -fx-border-color: #333; -fx-border-width: 2; -fx-pref-width: 130;">
                <Label text="EP 04" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                <Button fx:id="btnEp4" text="🔒" onAction="#jogarEp4" style="-fx-background-color: #444; -fx-text-fill: #888; -fx-font-size: 10px; -fx-pref-width: 110; -fx-pref-height: 40; -fx-font-family: 'Press Start 2P';" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.75); -fx-padding: 15; -fx-border-color: #333; -fx-border-width: 2; -fx-pref-width: 130;">
                <Label text="EP 05" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                <Button fx:id="btnEp5" text="🔒" onAction="#jogarEp5" style="-fx-background-color: #444; -fx-text-fill: #888; -fx-font-size: 10px; -fx-pref-width: 110; -fx-pref-height: 40; -fx-font-family: 'Press Start 2P';" />
            </VBox>

            <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.75); -fx-padding: 15; -fx-border-color: #333; -fx-border-width: 2; -fx-pref-width: 130;">
                <Label text="EP 06" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                <Button fx:id="btnEp6" text="🔒" onAction="#jogarEp6" style="-fx-background-color: #444; -fx-text-fill: #888; -fx-font-size: 10px; -fx-pref-width: 110; -fx-pref-height: 40; -fx-font-family: 'Press Start 2P';" />
            </VBox>

        </children>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
        <children>
            <Button onAction="#abrirInventario" text="🎒 INVENTÁRIO" style="-fx-background-color: #0077ff; -fx-text-fill: white; -fx-font-size: 11px; -fx-pref-width: 180; -fx-pref-height: 45; -fx-cursor: hand;" />
            <Button onAction="#voltarMenu" text="← VOLTAR" style="-fx-background-color: #333; -fx-text-fill: white; -fx-font-size: 11px; -fx-pref-width: 180; -fx-pref-height: 45; -fx-cursor: hand;" />
        </children>
    </HBox>

</AnchorPane>